APP_NAME="Travel Companion"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# --- Laravel Sail against the custom docker-compose.yml ---
# Sail defaults to service "laravel.test" and user "sail"; our stack names the
# PHP container "app" and runs it as root (deployment/docker/Dockerfile).
APP_SERVICE=app
APP_USER=root

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL + PostGIS + pgvector (see deployment/docker/postgres/)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=travel_companion
DB_USERNAME=travel
DB_PASSWORD=secret
# require on managed DBs; prefer for the local Docker container
DB_SSLMODE=prefer

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=travel

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Isolate keys on the shared staging Redis so they never collide with other apps
REDIS_PREFIX=travel_
HORIZON_PREFIX=travel_horizon:

# Registration allowlist (comma-separated). Empty = open registration.
ALLOWED_REGISTRATION_EMAILS="mats@beet.se,lexus.bergsten@gmail.com"

# Mail — required for password-reset and email-verification links to actually
# be delivered. Local dev defaults to `log` (writes the email to storage/logs
# instead of sending). For staging, set a real SMTP transport (values below are
# a placeholder shape — fill from your provider, e.g. Postmark/Resend/Mailgun/SES).
MAIL_MAILER=log
MAIL_SCHEME=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@travel.bergsten.net"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ============================================================================
# External API keys (docs/DATA-SOURCES.md — section refs below)
# Consumed via config/services.php only (conventions: no env() outside config).
# Empty = adapter disabled. Many core sources need NO key by design:
# OSM/Geofabrik, Overture, Wikidata/Wikipedia/Wikivoyage, DATAtourisme,
# POP/Mérimée, Open-Meteo free tier, MET Norway, NOAA aurora, GTFS feeds,
# astronomy (suncalc library), MapLibre+OSM tiles (admin map).
# ============================================================================

# --- LLM provider: Gemini (decided — PRD Appendix A), behind the LlmClient
#     port (conventions/10: cheap tier for summarization/tagging, capable tier
#     for comparison/wording; never a source of facts). Verify model IDs
#     against ai.google.dev/gemini-api/docs/models before go-live. ---
GEMINI_API_KEY=
GEMINI_MODEL_CHEAP=gemini-3.1-flash-lite
GEMINI_MODEL_CAPABLE=gemini-3.5-flash
# Alternate providers, unused for now (LlmClient makes switching a config change):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Enrichment edge (§2 — never persisted, edge-cache only): Google Places
#     API (New) for hours/photos verification + Google Routes for detour costs.
#     One Google Maps Platform key covers both. ---
GOOGLE_MAPS_API_KEY=

# --- Events (§3) ---
TICKETMASTER_API_KEY=
OPENAGENDA_API_KEY=
# P2 — verify current API terms before building the adapter (§3)
EVENTBRITE_API_TOKEN=

# --- Places, optional aggregator (§2, adds little over OSM+Wikidata) ---
OPENTRIPMAP_API_KEY=

# --- Context layers (§9) ---
# Open-Meteo needs no key on the free tier; set only if on the commercial plan.
OPEN_METEO_API_KEY=
# Tides for coastal opportunities outside France (SHOM is open for FR) — paid.
WORLDTIDES_API_KEY=
# EV charging (free key)
OPENCHARGEMAP_API_KEY=

# --- Layer 5 human-knowledge batch pipelines (§6, P2) ---
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Docker local dev port forwards (docker-compose.yml) ---
APP_PORT=80
VITE_PORT=5173
FORWARD_DB_PORT=5432
FORWARD_REDIS_PORT=6379
ADMINER_PORT=8080
