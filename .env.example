APP_NAME="Travel Companion"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# --- Laravel Sail against the custom docker-compose.yml ---
# Sail defaults to service "laravel.test" and user "sail"; our stack names the
# PHP container "app" and runs it as root (deployment/docker/Dockerfile).
APP_SERVICE=app
APP_USER=root

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL + PostGIS + pgvector (see deployment/docker/postgres/)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=travel_companion
DB_USERNAME=travel
DB_PASSWORD=secret
# require on managed DBs; prefer for the local Docker container
DB_SSLMODE=prefer

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=travel

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Isolate keys on the shared staging Redis so they never collide with other apps
REDIS_PREFIX=travel_
HORIZON_PREFIX=travel_horizon:

# Registration allowlist (comma-separated). Empty = open registration.
ALLOWED_REGISTRATION_EMAILS="mats@beet.se,lexus.bergsten@gmail.com"

# Mail — password-reset links (and email verification, when it ships) are only
# real if this transport is. Two environments, two drivers:
#
#   local    MAIL_MAILER=smtp   -> the Mailpit container (docker-compose.yml).
#                                 Nothing leaves the machine; read every sent
#                                 mail at http://localhost:8025.
#   staging  MAIL_MAILER=resend -> Resend's HTTP API (resend/resend-laravel).
#                                 Needs RESEND_API_KEY below and travel.bergsten.net
#                                 verified in Resend (SPF + DKIM in DNS).
#                                 MAIL_USERNAME/MAIL_PASSWORD are unused by this
#                                 driver — the key is the whole credential.
MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@travel.bergsten.net"
MAIL_FROM_NAME="${APP_NAME}"

# Read by config/services.php as services.resend.key. Only consumed when
# MAIL_MAILER=resend, so it can stay empty locally.
RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sign in with Google (E22). Google Cloud console → APIs & Services →
# Credentials → OAuth 2.0 Client ID, type "Web application". The redirect URI
# must match here and there byte for byte, port included.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ============================================================================
# External API keys (docs/DATA-SOURCES.md — section refs below)
# Consumed via config/services.php only (conventions: no env() outside config).
# Empty = adapter disabled. Many core sources need NO key by design:
# OSM/Geofabrik, Overture, Wikidata/Wikipedia/Wikivoyage, POP/Mérimée,
# Open-Meteo free tier, MET Norway, NOAA aurora, GTFS feeds,
# astronomy (suncalc library), MapLibre+OSM tiles (admin map).
# ============================================================================

# --- LLM provider: Gemini (decided — PRD Appendix A), behind the LlmClient
#     port (conventions/10: cheap tier for summarization/tagging, capable tier
#     for comparison/wording; never a source of facts). Verify model IDs
#     against ai.google.dev/gemini-api/docs/models before go-live. ---
GEMINI_API_KEY=
GEMINI_MODEL_CHEAP=gemini-3.1-flash-lite
GEMINI_MODEL_CAPABLE=gemini-3.5-flash
# Alternate providers, unused for now (LlmClient makes switching a config change):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Enrichment edge (§2 — never persisted, edge-cache only): Google Places
#     API (New) for hours/photos verification + Google Routes for detour costs.
#     One Google Maps Platform key covers both. ---
GOOGLE_MAPS_API_KEY=

# --- Stage-B routing engine (E43, PRD §10 / DATA-SOURCES §9). Default 'google';
#     flip to 'osrm' when the cost ledger says self-hosted routing pays for the
#     ops burden. Google stays a live fallback while OSRM earns trust, then set
#     OSRM_GOOGLE_FALLBACK=false (SERVER-DEPLOYMENT). ---
ROUTING_DRIVER=google
# One OSRM server per travel mode (OSRM serves ONE profile per process), each on its own
# host:port. Blank = that mode stays on Google via FallbackRouting — so the walking pilot can
# go self-hosted alone (set OSRM_URL_FOOT) and bike/drive follow later. All blank + the
# default ROUTING_DRIVER=google above means routing is 100% Google, which is the shipped
# state. NOT deployed yet — needs a box that can build an OSRM graph (see SERVER-DEPLOYMENT
# "Self-hosted routing": the shared staging box cannot, a small dedicated OSRM box can).
OSRM_URL_FOOT=
OSRM_URL_BIKE=
OSRM_URL_DRIVE=
OSRM_GOOGLE_FALLBACK=true

# --- Events (§3) ---
TICKETMASTER_API_KEY=
OPENAGENDA_API_KEY=
# P2 — verify current API terms before building the adapter (§3)
EVENTBRITE_API_TOKEN=

# --- France national open data (§7): DATAtourisme REST API (api.datatourisme.fr
#     /v1, docs at /v1/docs). Key comes from the form at
#     datatourisme.fr/utiliser-les-donnees and is sent as the X-API-Key header.
#     No flux/flux-ID here — that belongs to the older "plateforme diffuseur"
#     route, which is a separate account and a daily bulk dump, not this API.
#     Limits: 250 POIs/page, 10k results per query (shard by bbox/department to
#     go wider), ~1000 requests/hour. ---
DATATOURISME_API_KEY=

# --- Places, optional aggregator (§2, adds little over OSM+Wikidata) ---
OPENTRIPMAP_API_KEY=

# --- Image coverage (E50, DATA-SOURCES §15): free photo sources for places past
#     the 2.4% Wikidata wall. The trio already live — Commons GeoSearch, the OSM
#     image tags, Wikipedia lead images — needs NO key. Openverse (the CC pool) is
#     keyless too. Only Mapillary (crowd street-level imagery) needs a token.
#
#     Get it from the developer dashboard: https://www.mapillary.com/developer
#     Create an app; READ access uses only the CLIENT/ACCESS TOKEN below (it looks
#     like `MLY|...`). The client secret and the OAuth authorization URL are for
#     user-login flows we do NOT use — leave them out, only the token is needed.
#     Empty = Mapillary disabled; the other sources are unaffected.
#     QUOTE IT: the token contains a pipe (MLY|...), and an unquoted pipe in a .env can be
#     mangled by some parsers — write MAPILLARY_TOKEN="MLY|...". ---
MAPILLARY_TOKEN=

# --- Context layers (§9) ---
# Open-Meteo needs no key on the free tier; set only if on the commercial plan.
OPEN_METEO_API_KEY=
# Tides for coastal opportunities outside France (SHOM is open for FR) — paid.
WORLDTIDES_API_KEY=
# EV charging (free key)
OPENCHARGEMAP_API_KEY=

# --- Layer 5 human-knowledge batch pipelines (§6, P2) ---
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Push delivery (E31, Phase 2). The default sender is log-only and SAFE — a
#     misconfigured env that silently pushed to real phones is a worse failure
#     than one that pushes none. FCM activates only when FCM_PROJECT_ID is set,
#     AND only after the Google FCM data-processing agreement is signed
#     (legal/ROPA.md B13 — the one thing no code can close). ---
FCM_PROJECT_ID=
FCM_ACCESS_TOKEN=

# --- Docker local dev port forwards (docker-compose.yml) ---
APP_PORT=80
VITE_PORT=5173
FORWARD_DB_PORT=5432
FORWARD_REDIS_PORT=6379
ADMINER_PORT=8080
