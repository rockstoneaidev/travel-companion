APP_NAME="Travel Companion"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL + PostGIS + pgvector (see deployment/docker/postgres/)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=travel_companion
DB_USERNAME=travel
DB_PASSWORD=secret
# require on managed DBs; prefer for the local Docker container
DB_SSLMODE=prefer

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=travel

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Isolate keys on the shared staging Redis so they never collide with other apps
REDIS_PREFIX=travel_
HORIZON_PREFIX=travel_horizon:

# Registration allowlist (comma-separated). Empty = open registration.
ALLOWED_REGISTRATION_EMAILS="mats@beet.se,lexus.bergsten@gmail.com"

# Mail — required for password-reset and email-verification links to actually
# be delivered. Local dev defaults to `log` (writes the email to storage/logs
# instead of sending). For staging, set a real SMTP transport (values below are
# a placeholder shape — fill from your provider, e.g. Postmark/Resend/Mailgun/SES).
MAIL_MAILER=log
MAIL_SCHEME=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@travel.bergsten.net"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Docker local dev port forwards (docker-compose.yml) ---
APP_PORT=80
VITE_PORT=5173
FORWARD_DB_PORT=5432
FORWARD_REDIS_PORT=6379
ADMINER_PORT=8080
